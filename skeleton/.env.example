# =============================================================================
# ${{ values.name }} - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# ---- Application ----
NODE_ENV=development
APP_NAME=${{ values.name }}
PORT=${{ values.port }}
LOG_LEVEL=info

{% if values.sqlDatabase == 'postgresql' -%}
# ---- PostgreSQL ----
SQL_HOST=localhost
SQL_PORT=5432
SQL_DATABASE=${{ values.name }}
SQL_USER=postgres
SQL_PASSWORD=changeme
SQL_POOL_MIN=2
SQL_POOL_MAX=10
SQL_SSL=false
{% elif values.sqlDatabase == 'mysql' -%}
# ---- MySQL ----
SQL_HOST=localhost
SQL_PORT=3306
SQL_DATABASE=${{ values.name }}
SQL_USER=root
SQL_PASSWORD=changeme
SQL_POOL_MIN=2
SQL_POOL_MAX=10
SQL_SSL=false
{% endif -%}

{% if values.nosqlDatabase == 'mongodb' -%}
# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017/${{ values.name }}
MONGO_OPTIONS=retryWrites=true&w=majority
{% endif -%}

{% if values.nosqlDatabase == 'redis' or values.pubsubProvider == 'redis' -%}
# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
{% endif -%}

{% if values.pubsubProvider == 'kafka' -%}
# ---- Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=${{ values.name }}
KAFKA_GROUP_ID=${{ values.name }}-group
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
{% endif -%}

{% if values.pubsubProvider == 'rabbitmq' -%}
# ---- RabbitMQ ----
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=${{ values.name }}-exchange
RABBITMQ_QUEUE=${{ values.name }}-queue
{% endif -%}
