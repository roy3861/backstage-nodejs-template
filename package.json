{
  "name": "example-service",
  "version": "1.0.0",
  "description": "An example Node.js backend service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "migrate": "knex migrate:latest --knexfile src/database/sql/knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile src/database/sql/knexfile.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.4",
    "express-validator": "^7.0.1",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "mongoose": "^8.0.3",
    "kafkajs": "^2.2.4",
    "ioredis": "^5.4.1",
    "amqplib": "^0.10.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/hpp": "^0.2.5",
    "@types/uuid": "^9.0.7",
    "@types/amqplib": "^0.10.6",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "ts-jest": "^29.1.1",
    "jest": "^29.7.0",
    "eslint": "^9.32.0",
    "typescript-eslint": "^8.56.0",
    "supertest": "^7.2.2",
    "@types/supertest": "^6.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
