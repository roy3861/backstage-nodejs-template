{
  "name": "${{ values.name }}",
  "version": "1.0.0",
  "description": "${{ values.description }}",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "migrate": "knex migrate:latest --knexfile src/database/sql/knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile src/database/sql/knexfile.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.4",
    "express-validator": "^7.0.1",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
{%- if values.sqlDatabase == 'postgresql' %}
    "knex": "^3.1.0",
    "pg": "^8.11.3",
{%- elif values.sqlDatabase == 'mysql' %}
    "knex": "^3.1.0",
    "mysql2": "^3.6.5",
{%- endif %}
{%- if values.nosqlDatabase == 'mongodb' %}
    "mongoose": "^8.0.3",
{%- endif %}
{%- if values.nosqlDatabase == 'redis' or values.pubsubProvider == 'redis' %}
    "ioredis": "^5.3.2",
{%- endif %}
{%- if values.pubsubProvider == 'kafka' %}
    "kafkajs": "^2.2.4",
{%- endif %}
{%- if values.pubsubProvider == 'rabbitmq' %}
    "amqplib": "^0.10.3",
{%- endif %}
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/hpp": "^0.2.5",
    "@types/uuid": "^9.0.7",
    "@types/node": "^${{ values.nodeVersion }}.0.0",
    "@types/jest": "^29.5.11",
{%- if values.pubsubProvider == 'rabbitmq' %}
    "@types/amqplib": "^0.10.4",
{%- endif %}
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "ts-jest": "^29.1.1",
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.1"
  },
  "engines": {
    "node": ">=${{ values.nodeVersion }}.0.0"
  }
}
