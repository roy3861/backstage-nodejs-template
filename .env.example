# =============================================================================
# example-service - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# ---- Application ----
NODE_ENV=development
APP_NAME=example-service
PORT=3000
LOG_LEVEL=info

# ---- Module Feature Flags (set to true to enable) ----
ENABLE_SQL=false
ENABLE_MONGO=false
ENABLE_KAFKA=false
ENABLE_REDIS=false
ENABLE_RABBITMQ=false
ENABLE_AUTH=false
ENABLE_RATE_LIMIT=true
ENABLE_RESILIENCE=false
ENABLE_INTEGRATIONS=false
ENABLE_JOBS=false
ENABLE_CACHE=false
ENABLE_AUTHZ=false

# ---- PostgreSQL ----
SQL_HOST=localhost
SQL_PORT=5432
SQL_DATABASE=example-service
SQL_USER=postgres
SQL_PASSWORD=changeme
SQL_POOL_MIN=2
SQL_POOL_MAX=10
SQL_SSL=false

# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017/example-service
MONGO_OPTIONS=retryWrites=true&w=majority

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=example-service
KAFKA_GROUP_ID=example-service-group
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=example-service.exchange
RABBITMQ_QUEUE=example-service.queue

# ---- Resilience ----
RESILIENCE_TIMEOUT_MS=3000
RESILIENCE_RETRIES=3
RESILIENCE_RETRY_DELAY_MS=200
RESILIENCE_BREAKER_FAILURE_THRESHOLD=5
RESILIENCE_BREAKER_RESET_TIMEOUT_MS=10000

# ---- Integrations ----
INTEGRATIONS_EXAMPLE_API_BASE_URL=https://jsonplaceholder.typicode.com
INTEGRATIONS_TIMEOUT_MS=3000
INTEGRATIONS_API_TOKEN=

# ---- Jobs ----
JOBS_SAMPLE_INTERVAL_MS=60000

# ---- Cache ----
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_MAX_ITEMS=1000
CACHE_CLEANUP_INTERVAL_MS=30000

# ---- Authorization ----
AUTHZ_DEFAULT_ROLE=viewer
AUTHZ_TENANT_HEADER=x-tenant-id
